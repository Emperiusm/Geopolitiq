    "db:studio": "drizzle-kit studio",
    "seed": "bun src/seed/seed-from-mongo.ts"
  },
  "dependencies": {
    "@clickhouse/client": "^1.8.0",
    "@gambit/common": "workspace:*",
    "@hono/zod-validator": "^0.4.0",
    "@temporalio/client": "^1.11.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.7.0",
    "ioredis": "^5.10.1",
    "lru-cache": "^11.0.0",
    "minio": "^8.0.0",
    "mongodb": "^6.12.0",
    "neo4j-driver": "^6.0.1",
    "postgres": "^3.4.0",
    "typesense": "^2.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0",
