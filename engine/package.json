{
  "name": "gambit-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "bun x tsc --noEmit",
    "db:push": "drizzle-kit push",
